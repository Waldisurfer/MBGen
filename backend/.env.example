PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5174

# ── Admin setup ───────────────────────────────────────────────
# Comma-separated list of emails that are auto-promoted to admin on first login
ADMIN_EMAILS=your@email.com

# ── Logging ──────────────────────────────────────────────────
# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── Supabase (auth) ──────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── Database ─────────────────────────────────────────────────
# Runtime (pooler, port 6543) — used by the app at runtime
# From Supabase → Settings → Database → Connection string → Transaction
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Migrations (direct, port 5432) — used by drizzle-kit only
# From Supabase → Settings → Database → Connection string → Direct
DATABASE_URL_DIRECT=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Anthropic Claude ─────────────────────────────────────────
# Required for: campaign brief parsing, copy generation, animation config, prompt rewriting
ANTHROPIC_API_KEY=sk-ant-...

# ── Replicate (images + video) ───────────────────────────────
# Required for: ALL image models (FLUX, Recraft, Ideogram, SD) + Wan 2.1 / MiniMax / Luma video models
REPLICATE_API_KEY=r8_...

# ── Google / Veo 2 video — CHOOSE ONE of the two options below:
#
# Option A: AI Studio API key (simpler, recommended for local dev)
#   Get from: aistudio.google.com → API Keys
GOOGLE_GENAI_API_KEY=AIza...
#
# Option B: Vertex AI service account (for production / GCP environments)
#   GOOGLE_CLOUD_PROJECT=your-gcp-project-id
#   GOOGLE_CLOUD_LOCATION=us-central1
#   GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Cloudflare R2 (optional, permanent storage) ──────────────
# Get from: cloudflare.com → R2 → Manage API Tokens
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── SSE token signing ────────────────────────────────────────
# Required for: video generation status streams
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be stable across restarts — if unset, a random value is generated on each
# startup which invalidates all in-flight video SSE tokens on every restart/redeploy.
SSE_TOKEN_SECRET=replace-with-64-char-hex-secret
