PORT=3001
FRONTEND_URL=http://localhost:5174
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Anthropic Claude — console.anthropic.com → API Keys
# Required for: campaign brief parsing, copy generation, animation config, prompt rewriting
ANTHROPIC_API_KEY=sk-ant-...

# Replicate — replicate.com → Account → API Tokens
# Required for: ALL image models (FLUX, Recraft, Ideogram, SD) + Wan 2.1 / MiniMax / Luma video models
REPLICATE_API_KEY=r8_...

# Google / Veo 2 video — CHOOSE ONE of the two options below:
#
# Option A: AI Studio API key (simpler, recommended for local dev)
#   Get from: aistudio.google.com → API Keys
GOOGLE_GENAI_API_KEY=AIza...
#
# Option B: Vertex AI service account (for production / GCP environments)
#   GOOGLE_CLOUD_PROJECT=your-gcp-project-id
#   GOOGLE_CLOUD_LOCATION=us-central1
#   GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Cloudflare R2 — cloudflare.com → R2 → Manage API Tokens
# Required for: storing all generated images and videos (Replicate URLs expire in 1hr)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://pub-xxx.r2.dev
